{
  "name": "@g-abhishek/gitx",
  "version": "0.1.2",
  "description": "AI-powered Git workflow automation CLI and SDK",
  "type": "module",
  "license": "MIT",
  "author": "",
  "homepage": "",
  "repository": {
    "type": "git",
    "url": ""
  },
  "bugs": {
    "url": ""
  },
  "keywords": [
    "git",
    "cli",
    "github",
    "gitlab",
    "azure",
    "pull-request",
    "ai"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "gitx": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/postbuild-shebang.mjs ./dist/bin.js",
    "dev": "node --enable-source-maps dist/bin.js",
    "lint": "eslint .",
    "format": "prettier -w .",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "inquirer": "^10.2.2",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.7.0",
    "@types/node": "^20.14.10",
    "eslint": "^9.7.0",
    "globals": "^15.8.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.0.0"
  }
}
